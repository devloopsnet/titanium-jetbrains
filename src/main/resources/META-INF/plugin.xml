<idea-plugin>
    <id>com.tidev.titanium</id>
    <name>Titanium</name>
    <vendor url="https://titaniumsdk.com">Titanium Community</vendor>

    <description><![CDATA[
        <p>Develop <a href="https://titaniumsdk.com">Titanium SDK</a> apps and modules from any
        JetBrains IDE. Build, run, and clean apps on iOS simulators / Android emulators / devices,
        detect your environment, scaffold projects, and author Alloy views &amp; TSS styles.</p>
        <p>The core works on <b>every</b> IntelliJ-Platform IDE, including Community editions.
        JavaScript-controller intelligence lights up automatically on IDEs that ship the bundled
        JavaScript plugin (WebStorm, IDEA Ultimate, PhpStorm, PyCharm Pro, …).</p>
    ]]></description>

    <!-- Universal hard dependency: present in EVERY IntelliJ-Platform IDE (incl. Community). -->
    <depends>com.intellij.modules.platform</depends>
    <!-- XML support is also universal; we use it for Alloy view completion. -->
    <depends>com.intellij.modules.xml</depends>

    <!-- OPTIONAL: loads titanium-javascript.xml ONLY when the JavaScript plugin is present.
         This is what lets the plugin run on Community IDEs while still offering JS-controller
         intelligence on JS-bearing IDEs. -->
    <depends optional="true" config-file="titanium-javascript.xml">JavaScript</depends>

    <resource-bundle>messages.TitaniumBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Run configuration: the idiomatic home for build/run/clean. -->
        <configurationType implementation="com.tidev.titanium.run.TiRunConfigurationType"/>
        <runConfigurationProducer
            implementation="com.tidev.titanium.run.TiRunConfigurationProducer"/>

        <!-- Build explorer tool window (the VSCode activity-bar equivalent). -->
        <toolWindow id="Titanium"
                    anchor="left"
                    icon="/icons/toolwindow.svg"
                    factoryClass="com.tidev.titanium.toolwindow.TiToolWindowFactory"/>

        <!-- Help & Feedback (docs links + update check). -->
        <toolWindow id="Titanium Help"
                    anchor="left"
                    secondary="true"
                    icon="AllIcons.Actions.Help"
                    factoryClass="com.tidev.titanium.toolwindow.TiHelpToolWindowFactory"/>

        <!-- Settings page under Tools. -->
        <applicationConfigurable parentId="tools"
                                 id="com.tidev.titanium.settings"
                                 instance="com.tidev.titanium.settings.TiSettingsConfigurable"
                                 displayName="Titanium"/>

        <!-- Custom .tss file type (Alloy styles). Universal — needs no JS plugin. -->
        <fileType name="Alloy Style (TSS)"
                  language="TSS"
                  extensions="tss"
                  fieldName="INSTANCE"
                  implementationClass="com.tidev.titanium.tss.TssFileType"/>
        <lang.syntaxHighlighterFactory language="TSS"
                  implementationClass="com.tidev.titanium.tss.TssSyntaxHighlighterFactory"/>
        <lang.parserDefinition language="TSS"
                  implementationClass="com.tidev.titanium.tss.TssParserDefinition"/>
        <lang.braceMatcher language="TSS"
                  implementationClass="com.tidev.titanium.tss.TssBraceMatcher"/>
        <lang.commenter language="TSS"
                  implementationClass="com.tidev.titanium.tss.TssCommenter"/>
        <completion.contributor language="TSS"
                  implementationClass="com.tidev.titanium.tss.TssCompletionContributor"/>

        <!-- Alloy XML view + tiapp.xml completion. Universal (XML support is everywhere). -->
        <completion.contributor language="XML"
            implementationClass="com.tidev.titanium.alloy.AlloyViewCompletionContributor"/>
        <completion.contributor language="XML"
            implementationClass="com.tidev.titanium.alloy.AlloyTiappCompletionContributor"/>

        <!-- Hover / quick-doc from api.jsca descriptions. -->
        <lang.documentationProvider language="XML"
            implementationClass="com.tidev.titanium.alloy.AlloyDocumentationProvider"/>
        <lang.documentationProvider language="TSS"
            implementationClass="com.tidev.titanium.alloy.AlloyDocumentationProvider"/>

        <!-- Go-to-definition: event handler -> controller, i18n key -> strings.xml. -->
        <gotoDeclarationHandler
            implementation="com.tidev.titanium.alloy.AlloyGotoDeclarationHandler"/>

        <!-- Related-file gutter navigation (views/styles). JS controllers handled in optional file. -->
        <codeInsight.lineMarkerProvider language="XML"
            implementationClass="com.tidev.titanium.alloy.AlloyRelatedLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="TSS"
            implementationClass="com.tidev.titanium.alloy.AlloyRelatedLineMarkerProvider"/>

        <!-- Code intentions for Alloy views. -->
        <intentionAction>
            <language>XML</language>
            <className>com.tidev.titanium.intentions.AlloyInsertHandlerIntention</className>
            <category>Titanium</category>
        </intentionAction>
        <intentionAction>
            <language>XML</language>
            <className>com.tidev.titanium.intentions.AlloyInsertI18nIntention</className>
            <category>Titanium</category>
        </intentionAction>
        <intentionAction>
            <language>XML</language>
            <className>com.tidev.titanium.intentions.AlloyExtractStyleIntention</className>
            <category>Titanium</category>
        </intentionAction>

        <!-- Live templates: ti* (APIs) and al* (Alloy views). -->
        <defaultLiveTemplates file="liveTemplates/Titanium"/>
        <defaultLiveTemplates file="liveTemplates/Alloy"/>

        <!-- Debugger: attach to the Titanium runtime over Chrome DevTools Protocol. -->
        <programRunner implementation="com.tidev.titanium.debug.TiDebugRunner"/>
        <xdebugger.breakpointType implementation="com.tidev.titanium.debug.TiDebugBreakpointType"/>

        <!-- Notifications. -->
        <notificationGroup id="Titanium" displayType="BALLOON"/>

        <postStartupActivity implementation="com.tidev.titanium.core.TiStartupActivity"/>
    </extensions>

    <actions>
        <!-- Standalone actions (defined first so groups below can reference them). -->
        <action id="Titanium.Build"
                class="com.tidev.titanium.actions.TiBuildAction"
                icon="AllIcons.Actions.Execute"
                text="Build &amp; Run Titanium App"
                description="Build and run the selected (or default) Titanium configuration"/>
        <action id="Titanium.Debug"
                class="com.tidev.titanium.actions.TiDebugAction"
                icon="AllIcons.Actions.StartDebugger"
                text="Debug Titanium App"
                description="Debug the selected (or default) Titanium configuration"/>
        <action id="Titanium.Clean"
                class="com.tidev.titanium.actions.TiCleanAction"
                icon="AllIcons.Actions.GC"
                text="Clean Titanium Project"
                description="Run `ti clean` for the current project"/>
        <action id="Titanium.RefreshEnv"
                class="com.tidev.titanium.actions.TiRefreshEnvironmentAction"
                icon="AllIcons.Actions.Refresh"
                text="Refresh Titanium Environment"
                description="Re-run `ti info` to refresh SDKs, simulators and devices"/>
        <action id="Titanium.Package"
                class="com.tidev.titanium.actions.pkg.TiPackageAction"
                icon="AllIcons.Nodes.Artifact"
                text="Package for Distribution…"
                description="Distribution build: App Store / Ad Hoc (iOS) or Play Store (Android)"/>

        <!-- Menu: Tools | Titanium. -->
        <group id="Titanium.MainGroup" text="Titanium" popup="true" icon="/icons/titanium.svg"
               description="Titanium actions">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <reference ref="Titanium.Build"/>
            <reference ref="Titanium.Debug"/>
            <reference ref="Titanium.Package"/>
            <reference ref="Titanium.Clean"/>
            <reference ref="Titanium.RefreshEnv"/>

            <separator/>

            <action id="Titanium.CreateApp"
                    class="com.tidev.titanium.actions.create.TiCreateAppAction"
                    text="New Titanium App…"
                    description="Scaffold a Titanium app with `ti create`"/>
            <action id="Titanium.CreateModule"
                    class="com.tidev.titanium.actions.create.TiCreateModuleAction"
                    text="New Titanium Module…"
                    description="Scaffold a native Titanium module with `ti create`"/>

            <separator/>

            <group id="Titanium.Alloy.Generate" text="Generate Alloy" popup="true">
                <action id="Titanium.Alloy.Controller"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateControllerAction"
                        text="Controller…"/>
                <action id="Titanium.Alloy.View"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateViewAction"
                        text="View…"/>
                <action id="Titanium.Alloy.Style"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateStyleAction"
                        text="Style…"/>
                <action id="Titanium.Alloy.Model"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateModelAction"
                        text="Model…"/>
                <action id="Titanium.Alloy.Migration"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateMigrationAction"
                        text="Migration…"/>
                <action id="Titanium.Alloy.Widget"
                        class="com.tidev.titanium.actions.alloy.AlloyGenerateWidgetAction"
                        text="Widget…"/>
            </group>

            <separator/>

            <group id="Titanium.Alloy.Navigate" text="Open Related" popup="true">
                <action id="Titanium.Alloy.OpenController"
                        class="com.tidev.titanium.actions.alloy.OpenRelatedControllerAction"
                        text="Controller">
                    <keyboard-shortcut keymap="$default" first-keystroke="control alt X"/>
                </action>
                <action id="Titanium.Alloy.OpenView"
                        class="com.tidev.titanium.actions.alloy.OpenRelatedViewAction"
                        text="View">
                    <keyboard-shortcut keymap="$default" first-keystroke="control alt V"/>
                </action>
                <action id="Titanium.Alloy.OpenStyle"
                        class="com.tidev.titanium.actions.alloy.OpenRelatedStyleAction"
                        text="Style">
                    <keyboard-shortcut keymap="$default" first-keystroke="control alt S"/>
                </action>
                <action id="Titanium.Alloy.OpenAll"
                        class="com.tidev.titanium.actions.alloy.OpenAllRelatedFilesAction"
                        text="All Related Files">
                    <keyboard-shortcut keymap="$default" first-keystroke="control alt A"/>
                </action>
            </group>

            <separator/>

            <group id="Titanium.Sdk" text="SDK" popup="true">
                <action id="Titanium.Sdk.Install"
                        class="com.tidev.titanium.actions.sdk.TiInstallSdkAction"
                        text="Install SDK…"
                        description="Install a Titanium SDK with `ti sdk install`"/>
                <action id="Titanium.Sdk.Select"
                        class="com.tidev.titanium.actions.sdk.TiSelectSdkAction"
                        text="Select SDK…"
                        description="Choose the active Titanium SDK"/>
                <action id="Titanium.Sdk.CheckUpdates"
                        class="com.tidev.titanium.actions.sdk.TiCheckUpdatesAction"
                        text="Check for Updates"
                        description="Check whether a newer Titanium SDK is available"/>
                <separator/>
                <action id="Titanium.Sdk.UpdateCli"
                        class="com.tidev.titanium.actions.sdk.TiUpdateCliAction"
                        text="Update Titanium CLI"
                        description="npm install -g titanium"/>
                <action id="Titanium.Sdk.UpdateAlloy"
                        class="com.tidev.titanium.actions.sdk.TiUpdateAlloyAction"
                        text="Update Alloy CLI"
                        description="npm install -g alloy"/>
                <action id="Titanium.CreateKeystore"
                        class="com.tidev.titanium.actions.pkg.TiCreateKeystoreAction"
                        text="Create Android Keystore…"
                        description="Generate an Android signing keystore with keytool"/>
            </group>

            <separator/>

            <action id="Titanium.LiveView"
                    class="com.tidev.titanium.actions.TiLiveViewToggleAction"
                    text="Enable LiveView"
                    description="Toggle LiveView (--liveview) for dev builds"/>
            <action id="Titanium.SetLogLevel"
                    class="com.tidev.titanium.actions.TiSetLogLevelAction"
                    text="Set Log Level…"
                    description="Choose the CLI log level"/>

        </group>

        <!-- Platform + device pickers (values resolved from `ti info`). -->
        <action id="Titanium.SelectPlatform"
                class="com.tidev.titanium.actions.TiPlatformComboAction"
                text="Platform" description="Choose the platform to run on"/>
        <action id="Titanium.SelectDevice"
                class="com.tidev.titanium.actions.TiDeviceComboAction"
                text="Device" description="Choose the device/simulator to run on"/>

        <!-- Main (top) toolbar: platform/device pickers + Build / Debug / Clean / Refresh + Titanium dropdown. -->
        <group id="Titanium.Toolbar">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <reference ref="Titanium.SelectPlatform"/>
            <reference ref="Titanium.SelectDevice"/>
            <separator/>
            <reference ref="Titanium.Build"/>
            <reference ref="Titanium.Debug"/>
            <reference ref="Titanium.Package"/>
            <reference ref="Titanium.Clean"/>
            <reference ref="Titanium.RefreshEnv"/>
            <reference ref="Titanium.MainGroup"/>
        </group>

        <!-- Also offer the Alloy generators from the project-view right-click menu. -->
        <group id="Titanium.Alloy.Generate.ProjectView" text="Generate Alloy" popup="true" icon="/icons/titanium.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="NewGroup"/>
            <reference ref="Titanium.Alloy.Controller"/>
            <reference ref="Titanium.Alloy.View"/>
            <reference ref="Titanium.Alloy.Style"/>
            <reference ref="Titanium.Alloy.Model"/>
            <reference ref="Titanium.Alloy.Migration"/>
            <reference ref="Titanium.Alloy.Widget"/>
        </group>
    </actions>
</idea-plugin>
